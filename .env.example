# macOS signing identity — from "Developer ID Application: Name (TEAMID)"
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)

# Apple ID and app-specific password (generate at appleid.apple.com → App-Specific Passwords)
APPLE_ID=you@example.com
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 10-character team ID — visible in developer.apple.com or in the signing identity above
APPLE_TEAM_ID=XXXXXXXXXX

# GitHub repo where releases are published (owner/repo)
RELEASE_REPO=mqtik/muse
